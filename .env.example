# Copy this file to .env and fill in your values, then:
#   source .env
# Or export each variable individually before running podman-compose.

# Anthropic API key for Claude Code (inside the container)
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-...

# GitHub token for mise tool downloads (avoids rate limiting)
# Create at https://github.com/settings/tokens — no scopes required
MISE_GITHUB_TOKEN=ghp_...

# JWT signing key for Open WebUI sessions
# Generate with: openssl rand -hex 32
WEBUI_SECRET_KEY=

# Cloudflare Tunnel UUID to expose Open WebUI publicly
# Find with: cloudflared tunnel list
CLOUDFLARED_TUNNEL_ID=
