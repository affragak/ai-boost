# ai-boost environment variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# podman-compose reads .env automatically — no need to export anything.
# .env is git-ignored — never commit it.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# JWT signing key for Open WebUI sessions.
# Generate once and keep it stable — changing it signs out all users.
#   openssl rand -hex 32
WEBUI_SECRET_KEY=

# UUID of your Cloudflare Tunnel.
# Find it with: cloudflared tunnel list
CLOUDFLARED_TUNNEL_ID=

# ── Optional (but recommended) ────────────────────────────────────────────────

# Anthropic API key — required for Claude Code inside the container.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# GitHub personal access token — used by mise to avoid rate-limiting when
# downloading tools. Needs no scopes (public repos only).
# Create one at https://github.com/settings/tokens
MISE_GITHUB_TOKEN=

# ── Open WebUI admin credentials ─────────────────────────────────────────────
# Used by make fix-model-access, make list-users, and make create-user.
# Set these after you create your admin account at http://localhost:8080.

OPENWEBUI_ADMIN_EMAIL=
OPENWEBUI_ADMIN_PASSWORD=
