#!/bin/bash
set -e

OPENWEBUI_URL="http://localhost:8080"

usage() {
  cat <<EOF
Usage: create-user --admin-email EMAIL --admin-password PASSWORD \\
                   --name NAME --email EMAIL --password PASSWORD

Creates a new user in Open WebUI with role 'user' and access to all
currently available models.

Options:
  --admin-email      Admin account email
  --admin-password   Admin account password
  --name             Display name for the new user
  --email            Email for the new user
  --password         Password for the new user
EOF
  exit 1
}

die() { echo "Error: $*" >&2; exit 1; }

# Parse arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    --admin-email)    ADMIN_EMAIL="$2";    shift 2 ;;
    --admin-password) ADMIN_PASSWORD="$2"; shift 2 ;;
    --name)           USER_NAME="$2";      shift 2 ;;
    --email)          USER_EMAIL="$2";     shift 2 ;;
    --password)       USER_PASSWORD="$2";  shift 2 ;;
    *) usage ;;
  esac
done

[[ -z "$ADMIN_EMAIL" || -z "$ADMIN_PASSWORD" || -z "$USER_NAME" || -z "$USER_EMAIL" || -z "$USER_PASSWORD" ]] && usage

# Export all values — Python reads from os.environ to avoid shell quoting issues
export _CU_ADMIN_EMAIL="$ADMIN_EMAIL"
export _CU_ADMIN_PASSWORD="$ADMIN_PASSWORD"
export _CU_USER_NAME="$USER_NAME"
export _CU_USER_EMAIL="$USER_EMAIL"
export _CU_USER_PASSWORD="$USER_PASSWORD"
export _CU_URL="$OPENWEBUI_URL"

python3 - <<'PYEOF'
import json, os, sys, urllib.request, urllib.error

url          = os.environ["_CU_URL"]
admin_email  = os.environ["_CU_ADMIN_EMAIL"]
admin_pass   = os.environ["_CU_ADMIN_PASSWORD"]
user_name    = os.environ["_CU_USER_NAME"]
user_email   = os.environ["_CU_USER_EMAIL"]
user_pass    = os.environ["_CU_USER_PASSWORD"]

def request(method, path, data=None, token=None):
    headers = {"Content-Type": "application/json"}
    if token:
        headers["Authorization"] = f"Bearer {token}"
    req = urllib.request.Request(
        f"{url}{path}", method=method,
        data=json.dumps(data).encode() if data else None,
        headers=headers,
    )
    try:
        with urllib.request.urlopen(req) as r:
            return json.load(r)
    except urllib.error.HTTPError as e:
        body = e.read().decode()
        print(f"Error: HTTP {e.code} — {body}", file=sys.stderr)
        sys.exit(1)

# Authenticate as admin
print("Authenticating as admin...")
auth = request("POST", "/api/v1/auths/signin",
               {"email": admin_email, "password": admin_pass})
token = auth["token"]

# Create user
print(f"Creating user '{user_name}' ({user_email})...")
user = request("POST", "/api/v1/auths/add",
               {"name": user_name, "email": user_email,
                "password": user_pass, "role": "user"}, token)
print(f"  Created: {user['name']} ({user['email']}) role={user['role']}")

# Grant access to all models
print("Granting model access...")
models_resp = request("GET", "/api/v1/models", token=token)
models = models_resp if isinstance(models_resp, list) else models_resp.get("data", [])
for m in models:
    mid = m.get("id")
    if not mid:
        continue
    request("POST", "/api/v1/models/model/access/update",
            {"id": mid, "access_control": None, "access_grants": []}, token)
    print(f"  Model access set: {mid}")

print(f"\nDone. User '{user_name}' can now log in at {url}")
PYEOF
