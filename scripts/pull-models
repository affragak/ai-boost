#!/bin/bash
set -e

# Models pulled on first run inside the container.
# Add or remove entries to customise your local model set.
#
# | Model                                      | Size  | Purpose                        |
# |--------------------------------------------|-------|--------------------------------|
# | llama3.1:8b                                | ~5 GB | General-purpose chat           |
# | qwen2.5:7b                                 | ~5 GB | General-purpose chat           |
# | deepseek-coder-v2:16b-lite-instruct-q4_K_M | ~9 GB | Code generation / assistance   |
# | mistral-nemo                               | ~7 GB | General-purpose chat           |
# | nomic-embed-text                           | ~274 MB | RAG embeddings (Open WebUI)  |
MODELS=(
  "llama3.1:8b"
  "qwen2.5:7b"
  "deepseek-coder-v2:16b-lite-instruct-q4_K_M"
  "mistral-nemo"
  "nomic-embed-text"
)

for model in "${MODELS[@]}"; do
  if ollama list 2>/dev/null | grep -q "^${model}"; then
    echo "Skipping $model (already present)"
  else
    echo "Pulling $model..."
    ollama pull "$model"
  fi
done

echo "All models ready."
