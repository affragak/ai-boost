#!/bin/bash
set -e

# Models pulled on first run inside the container.
# Add or remove entries to customise your local model set.
# Sized for 8 GB VRAM (NVIDIA RTX 5060) — keep models at Q4 ≤ ~8 GB.
#
# | Model                      | Size     | Purpose                          |
# |----------------------------|----------|----------------------------------|
# | qwen2.5:7b                 | ~5 GB    | General-purpose chat             |
# | mistral-nemo               | ~7 GB    | General-purpose chat             |
# | gemma2:9b-instruct-q4_K_M  | ~5.5 GB  | Reasoning / analysis             |
# | phi4:14b-q4_K_M            | ~8 GB    | Heavy reasoning (fills VRAM)     |
# | qwen2.5-coder:7b           | ~5 GB    | Code generation / assistance     |
# | llava:7b                   | ~4.5 GB  | Multimodal — image understanding |
# | nomic-embed-text           | ~274 MB  | RAG embeddings (Open WebUI)      |
# | mxbai-embed-large          | ~670 MB  | Higher-quality RAG embeddings    |
MODELS=(
  "qwen2.5:7b"
  "mistral-nemo"
  "gemma2:9b-instruct-q4_K_M"
  "phi4:14b-q4_K_M"
  "qwen2.5-coder:7b"
  "llava:7b"
  "nomic-embed-text"
  "mxbai-embed-large"
)

for model in "${MODELS[@]}"; do
  if ollama list 2>/dev/null | grep -q "^${model}"; then
    echo "Skipping $model (already present)"
  else
    echo "Pulling $model..."
    ollama pull "$model"
  fi
done

echo "All models ready."

# If admin credentials are available, sync model access grants so all
# Open WebUI users can see the newly pulled models.
if [[ -n "$OPENWEBUI_ADMIN_EMAIL" && -n "$OPENWEBUI_ADMIN_PASSWORD" ]]; then
  echo "Syncing model access grants..."
  fix-model-access
fi
